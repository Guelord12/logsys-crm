<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <style>
    body { font-family: Arial, sans-serif; line-height: 1.6; color: #333; }
    .container { max-width: 600px; margin: 0 auto; padding: 20px; }
    .header { text-align: center; padding: 20px 0; background: linear-gradient(135deg, #4A90E2, #2E5FA1); color: white; border-radius: 10px 10px 0 0; }
    .content { padding: 30px; background: #f9f9f9; }
    .footer { text-align: center; padding: 20px; color: #666; font-size: 12px; }
    .button { display: inline-block; padding: 12px 24px; background: #4A90E2; color: white; text-decoration: none; border-radius: 5px; margin: 20px 0; }
    .meeting-details { background: #fff; padding: 15px; border-radius: 5px; margin: 20px 0; border: 1px solid #ddd; }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1>Invitation à une réunion</h1>
    </div>
    <div class="content">
      <p>Bonjour {{name}},</p>
      <p>{{organizerName}} vous invite à une réunion.</p>
      <div class="meeting-details">
        <p><strong>{{meetingTitle}}</strong></p>
        <p>{{meetingDescription}}</p>
        <p><strong>Date :</strong> {{startTime}}</p>
        <p><strong>Durée :</strong> {{duration}}</p>
        {{#if meetingUrl}}
        <p><strong>Lien de la réunion :</strong> <a href="{{meetingUrl}}">{{meetingUrl}}</a></p>
        {{/if}}
      </div>
      <p style="text-align: center;">
        <a href="{{meetingUrl}}" class="button">Rejoindre la réunion</a>
      </p>
    </div>
    <div class="footer">
      <p>© {{year}} LogSys CRM - Tous droits réservés</p>
      <p>From G-tech</p>
    </div>
  </div>
</body>
</html>