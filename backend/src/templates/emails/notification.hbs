<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8">
  <style>
    body { font-family: Arial, sans-serif; line-height: 1.6; color: #333; }
    .container { max-width: 600px; margin: 0 auto; padding: 20px; }
    .header { text-align: center; padding: 20px 0; background: linear-gradient(135deg, #4A90E2, #2E5FA1); color: white; border-radius: 10px 10px 0 0; }
    .content { padding: 30px; background: #f9f9f9; }
    .footer { text-align: center; padding: 20px; color: #666; font-size: 12px; }
    .button { display: inline-block; padding: 10px 20px; background: #4A90E2; color: white; text-decoration: none; border-radius: 5px; margin: 20px 0; }
    .message { background: #fff; padding: 15px; border-radius: 5px; margin: 20px 0; border: 1px solid #ddd; }
  </style>
</head>
<body>
  <div class="container">
    <div class="header">
      <h1>{{title}}</h1>
    </div>
    <div class="content">
      <p>Bonjour {{fullName}},</p>
      <div class="message">
        <p>{{message}}</p>
      </div>
      {{#if actionUrl}}
      <p style="text-align: center;">
        <a href="{{actionUrl}}" class="button">{{actionText}}</a>
      </p>
      {{/if}}
      <p>Connectez-vous à LogSys CRM pour plus de détails.</p>
    </div>
    <div class="footer">
      <p>© {{year}} LogSys CRM - Tous droits réservés</p>
      <p>From G-tech</p>
    </div>
  </div>
</body>
</html>